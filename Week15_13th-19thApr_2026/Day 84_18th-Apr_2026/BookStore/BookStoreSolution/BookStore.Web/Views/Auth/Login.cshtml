@model LoginViewModel
@{ ViewData["Title"] = "Sign In"; }

<div class="auth-wrap">
    <div class="card auth-card">
        <div class="card-body">
            <div>
                <div class="auth-title">Welcome back</div>
                <div class="auth-sub">Sign in to your BookStore Pro account.</div>
            </div>

            <form asp-action="Login" method="post" class="stack">
                @{
                    var err = ViewData.ModelState["Error"];
                    if (err != null && err.Errors.Any())
                    {
                        <div class="alert alert-danger">@err.Errors[0].ErrorMessage</div>
                    }
                }
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-full">Sign In</button>
            </form>

            <div class="auth-footer">
                Don't have an account? <a asp-action="Register">Create one</a>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }