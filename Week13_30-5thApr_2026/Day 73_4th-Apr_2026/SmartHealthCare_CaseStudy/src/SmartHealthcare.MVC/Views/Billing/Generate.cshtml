@model SmartHealthcare.Models.DTOs.GenerateBillDTO

@{
    ViewData["Title"] = "Generate Bill";
    var appointment = ViewBag.Appointment as SmartHealthcare.Models.DTOs.AppointmentDTO;
    var prescription = ViewBag.Prescription as SmartHealthcare.Models.DTOs.PrescriptionDTO;
    var medicineCount = prescription?.Medicines?.Count ?? 0;
    var defaultPerMedicine = 50m;
    var suggestedMedicineTotal = medicineCount * defaultPerMedicine;
}

<div class="container py-4">

    @* ── Page header ── *@
    <div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="mb-1 fw-semibold text-success">
                <i class="bi bi-receipt me-2"></i>Generate Bill
            </h2>
            @if (appointment != null)
            {
                <p class="text-muted mb-0">
                    Appointment <strong>#@appointment.Id</strong> &mdash;
                    Patient: <strong>@appointment.PatientName</strong> &mdash;
                    Dr. <strong>@appointment.DoctorName</strong>
                </p>
                <p class="text-muted small mb-0">
                    <i class="bi bi-calendar me-1"></i>
                    @appointment.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")
                </p>
            }
        </div>
        <a asp-controller="Appointment" asp-action="Details"
           asp-route-id="@Model.AppointmentId"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Appointment
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Generate" asp-controller="Billing" method="post" id="generateBillForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="AppointmentId" />

        <div class="row g-4">

            @* ── Left: Appointment + Prescription summary ── *@
            <div class="col-lg-5">

                @* Appointment summary card *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h6 class="mb-0">
                            <i class="bi bi-calendar-check me-2"></i>Appointment Summary
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        @if (appointment != null)
                        {
                            <dl class="row mb-0 small">
                                <dt class="col-5 text-muted">Patient</dt>
                                <dd class="col-7 fw-semibold">@appointment.PatientName</dd>

                                <dt class="col-5 text-muted">Doctor</dt>
                                <dd class="col-7">Dr. @appointment.DoctorName</dd>

                                <dt class="col-5 text-muted">Date</dt>
                                <dd class="col-7">@appointment.AppointmentDate.ToString("dd MMM yyyy")</dd>

                                <dt class="col-5 text-muted">Status</dt>
                                <dd class="col-7">
                                    <span class="badge @(appointment.Status == "Completed" ? "bg-success" :
                                                                                  appointment.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
                                    @appointment.Status
                                </span>
                            </dd>
                        </dl>
                                                }
                    </div>
                </div>

                @* Prescription summary card *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-success text-white py-3">
                        <h6 class="mb-0">
                            <i class="bi bi-capsule me-2"></i>Prescription Summary
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        @if (prescription == null)
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-file-earmark-x d-block fs-3 mb-2"></i>
                                <p class="small mb-0">No prescription has been written for this appointment.</p>
                                <p class="small text-warning mt-1">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    Medicine charges will be ₹0 unless overridden below.
                                </p>
                            </div>
                        }
                        else
                        {
                            <p class="small text-muted mb-2">
                                <strong>Diagnosis:</strong> @prescription.Diagnosis
                            </p>
                            <p class="small text-muted mb-3">
                                <strong>Medicines:</strong>
                                <span class="badge bg-success rounded-pill ms-1">@medicineCount</span>
                            </p>

                            @if (prescription.Medicines != null && prescription.Medicines.Any())
                            {
                                <ul class="list-group list-group-flush small">
                                    @foreach (var med in prescription.Medicines)
                                    {
                                        <li class="list-group-item px-0 py-1 d-flex justify-content-between">
                                            <span>
                                                <i class="bi bi-capsule-pill text-success me-1"></i>
                                                @med.Name
                                            </span>
                                            <span class="text-muted">@med.Dosage</span>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                </div>

            </div>

            @* ── Right: Bill configuration ── *@
            <div class="col-lg-7">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-calculator me-2"></i>Bill Configuration
                        </h5>
                    </div>
                    <div class="card-body p-4">

                        @* ── Live bill preview ── *@
                        <div class="card bg-light border-0 mb-4" id="billPreviewCard">
                            <div class="card-body p-3">
                                <h6 class="fw-semibold mb-3 text-success">
                                    <i class="bi bi-eye me-2"></i>Live Preview
                                </h6>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Consultation Fee</span>
                                    <span class="fw-semibold" id="previewConsultation">₹0.00</span>
                                </div>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">
                                        Medicine Charges
                                        <span class="text-muted" id="previewMedicineNote">
                                            (@medicineCount medicines × ₹<span id="previewRate">50</span>)
                                        </span>
                                    </span>
                                    <span class="fw-semibold" id="previewMedicine">
                                        ₹@suggestedMedicineTotal.ToString("N2")
                                    </span>
                                </div>
                                <hr class="my-2" />
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">Total Amount</span>
                                    <span class="fw-bold text-success fs-5" id="previewTotal">
                                        ₹@suggestedMedicineTotal.ToString("N2")
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* ── Per-medicine rate (used for auto-calculation) ── *@
                        <div class="mb-4">
                            <label asp-for="PerMedicineCharge" class="form-label fw-semibold">
                                Charge Per Medicine (₹)
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="PerMedicineCharge"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       max="10000"
                                       class="form-control"
                                       id="perMedicineInput"
                                       placeholder="50.00" />
                            </div>
                            <div class="form-text">
                                Applied to each of the <strong>@medicineCount medicine(s)</strong>
                                in the prescription. Suggested total:
                                <strong id="suggestedMedicineTotal">
                                    ₹@suggestedMedicineTotal.ToString("N2")
                                </strong>
                            </div>
                            <span asp-validation-for="PerMedicineCharge" class="text-danger small"></span>
                        </div>

                        @* ── Optional medicine charge override ── *@
                        <div class="mb-4">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox"
                                       id="overrideToggle" role="switch" />
                                <label class="form-check-label fw-semibold" for="overrideToggle">
                                    Override medicine charges manually
                                </label>
                            </div>
                            <div id="overrideSection" style="display:none;">
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input asp-for="MedicineChargesOverride"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           max="100000"
                                           class="form-control"
                                           id="medicineOverrideInput"
                                           placeholder="Enter exact medicine charges" />
                                </div>
                                <div class="form-text text-warning">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    This overrides the per-medicine calculation entirely.
                                </div>
                                <span asp-validation-for="MedicineChargesOverride" class="text-danger small"></span>
                            </div>
                        </div>

                        @* ── Notes ── *@
                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">
                                Bill Notes
                                <span class="text-muted fw-normal">(optional)</span>
                            </label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="e.g. Insurance applied, 10% discount, follow-up included..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        @* ── Info box: consultation fee note ── *@
                        <div class="alert alert-info small d-flex gap-2 align-items-start">
                            <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
                            <div>
                                The <strong>consultation fee</strong> is automatically pulled from the
                                doctor's profile and cannot be changed here. If it needs to be corrected,
                                update the doctor's profile fee first.
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        @* ── Submit buttons ── *@
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-controller="Appointment"
               asp-action="Details"
               asp-route-id="@Model.AppointmentId"
               class="btn btn-outline-secondary btn-lg px-4">
                <i class="bi bi-x-circle me-2"></i>Cancel
            </a>
            <button type="submit" class="btn btn-success btn-lg px-5" id="generateBtn">
                <i class="bi bi-receipt me-2"></i>Generate Bill
            </button>
        </div>

    </form>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {

            // The consultation fee from the doctor's profile — passed from ViewBag
            // We show it in the preview but it is not editable on this form
            // The actual value is read from the doctor entity in the service
            const consultationFee = @(appointment?.ConsultationFee.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "0");
            const medicineCount = @medicineCount;

            // ── Update the live preview whenever inputs change
            function updatePreview() {
                const useOverride = $('#overrideToggle').is(':checked');
                const perRate = parseFloat($('#perMedicineInput').val()) || 0;
                const overrideVal = parseFloat($('#medicineOverrideInput').val()) || 0;

                let medicineCharge = useOverride
                    ? overrideVal
                    : (medicineCount * perRate);

                const total = consultationFee + medicineCharge;

                $('#previewConsultation').text('₹' + consultationFee.toFixed(2));
                $('#previewMedicine').text('₹' + medicineCharge.toFixed(2));
                $('#previewTotal').text('₹' + total.toFixed(2));
                $('#previewRate').text(perRate.toFixed(0));

                // Update the suggested total label too
                const suggested = medicineCount * perRate;
                $('#suggestedMedicineTotal').text('₹' + suggested.toFixed(2));

                // Colour the total green if positive, red if somehow negative
                $('#previewTotal')
                    .toggleClass('text-success', total >= 0)
                    .toggleClass('text-danger', total < 0);
            }

            // ── Override toggle
            $('#overrideToggle').on('change', function () {
                if ($(this).is(':checked')) {
                    $('#overrideSection').slideDown(200);
                    $('#perMedicineInput').prop('disabled', true)
                        .closest('.mb-4').addClass('opacity-50');
                } else {
                    $('#overrideSection').slideUp(200);
                    $('#perMedicineInput').prop('disabled', false)
                        .closest('.mb-4').removeClass('opacity-50');
                    $('#medicineOverrideInput').val('');
                }
                updatePreview();
            });

            $('#perMedicineInput').on('input', updatePreview);
            $('#medicineOverrideInput').on('input', updatePreview);

            // Run on load so the preview is correct immediately
            updatePreview();

            // ── Prevent double submission
            $('#generateBillForm').on('submit', function () {
                $('#generateBtn')
                    .prop('disabled', true)
                    .html('<span class="spinner-border spinner-border-sm me-2"></span>Generating...');
            });

        });
    </script>
}