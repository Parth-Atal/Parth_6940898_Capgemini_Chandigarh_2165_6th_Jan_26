@model SmartHealthcare.Models.DTOs.BillDTO

@{
    ViewData["Title"] = $"Bill #{Model.Id}";
    var role = ViewBag.Role as string;
    var isDoctor = role == "Doctor";
    var isAdmin = role == "Admin";
    var isUnpaid = Model.PaymentStatus == "Unpaid";
    var isPaid = Model.PaymentStatus == "Paid";
    var isWaived = Model.PaymentStatus == "Waived";
}

<div class="container py-4">

    @* ── Alerts ── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show">
            <i class="bi bi-info-circle-fill me-2"></i>@TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Action bar (hidden when printing) ── *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2 no-print">
        <div>
            <h2 class="mb-1 fw-semibold">
                <i class="bi bi-receipt me-2 text-success"></i>Bill
                <span class="text-muted">#@Model.Id</span>
            </h2>
            <p class="text-muted mb-0 small">
                Generated on @Model.GeneratedAt.ToString("dd MMM yyyy, hh:mm tt")
            </p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Appointment" asp-action="Details"
               asp-route-id="@Model.AppointmentId"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Appointment
            </a>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Print Bill
            </button>

            @* Mark as Paid — doctor or admin, only when Unpaid *@
            @if ((isDoctor || isAdmin) && isUnpaid)
            {
                <button type="button"
                        class="btn btn-success btn-sm"
                        data-bs-toggle="modal"
                        data-bs-target="#markPaidModal">
                    <i class="bi bi-check-circle me-1"></i>Mark as Paid
                </button>
            }

            @* Waive — admin only, only when Unpaid *@
            @if (isAdmin && isUnpaid)
            {
                <button type="button"
                        class="btn btn-warning btn-sm text-dark"
                        data-bs-toggle="modal"
                        data-bs-target="#waiveModal">
                    <i class="bi bi-slash-circle me-1"></i>Waive Bill
                </button>
            }

            @* Revert to Unpaid — admin only, only when Paid *@
            @if (isAdmin && isPaid)
            {
                <button type="button"
                        class="btn btn-outline-warning btn-sm"
                        data-bs-toggle="modal"
                        data-bs-target="#revertModal">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Revert to Unpaid
                </button>
            }

            @* Delete — admin only *@
            @if (isAdmin)
            {
                <button type="button"
                        class="btn btn-outline-danger btn-sm"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteModal">
                    <i class="bi bi-trash3 me-1"></i>Delete
                </button>
            }
        </div>
    </div>

    @* ════════════════════════════════════════════════════════════
         PRINTABLE BILL — everything inside this div gets printed
       ════════════════════════════════════════════════════════════ *@
    <div id="printableBill">

        @* ── Hospital letterhead ── *@
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h3 class="fw-bold text-primary mb-1">
                            <i class="bi bi-hospital me-2"></i>SmartHealthCare Hospital
                        </h3>
                        <p class="text-muted small mb-0">
                            123 Healthcare Avenue, Medical District &bull;
                            contact@smarthealthcare.com &bull;
                            +91 98765 43210
                        </p>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <div class="d-inline-block text-start">
                            <p class="mb-0 small text-muted">Bill Number</p>
                            <p class="fw-bold fs-5 mb-0">#@Model.Id.ToString("D6")</p>
                            <p class="mb-0 small text-muted">Generated</p>
                            <p class="small mb-0">@Model.GeneratedAt.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Status banner ── *@
        <div class="alert @(isPaid ? "alert-success" : isWaived ? "alert-warning" : "alert-danger") d-flex align-items-center gap-3 mb-4">
            <i class="bi @(isPaid ? "bi-check-circle-fill" : isWaived ? "bi-slash-circle-fill" : "bi-clock-fill") fs-4 flex-shrink-0"></i>
            <div>
                <strong class="d-block">
                    @if (isPaid)
                    {
                        <span>Payment Received</span>
                    }
                    else if (isWaived)
                    {
                        <span>Bill Waived</span>
                    }
                    else
                    {
                        <span>Payment Pending</span>
                    }
                </strong>
                <span class="small">
                    @if (isPaid && Model.PaidAt.HasValue)
                    {
                        <span>Paid on @Model.PaidAt.Value.ToString("dd MMM yyyy, hh:mm tt")</span>
                    }
                    else if (isWaived)
                    {
                        <span>This bill has been waived by the administrator.</span>
                    }
                    else
                    {
                        <span>Please settle this bill at the billing counter or online.</span>
                    }
                </span>
            </div>
            <span class="ms-auto badge fs-6 @(isPaid ? "bg-success" : isWaived ? "bg-warning text-dark" : "bg-danger")">
                @Model.PaymentStatus
            </span>
        </div>

        <div class="row g-4 mb-4">

            @* ── Patient details ── *@
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-primary text-white py-2">
                        <h6 class="mb-0">
                            <i class="bi bi-person-fill me-2"></i>Bill To (Patient)
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Name</dt>
                            <dd class="col-7 fw-semibold">@Model.PatientName</dd>

                            <dt class="col-5 text-muted">Patient ID</dt>
                            <dd class="col-7">#@Model.PatientId</dd>

                            <dt class="col-5 text-muted">Appointment</dt>
                            <dd class="col-7">#@Model.AppointmentId</dd>

                            <dt class="col-5 text-muted">Appt. Date</dt>
                            <dd class="col-7">
                                @Model.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>

            @* ── Doctor details ── *@
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-success text-white py-2">
                        <h6 class="mb-0">
                            <i class="bi bi-person-badge-fill me-2"></i>Treating Doctor
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Name</dt>
                            <dd class="col-7 fw-semibold">Dr. @Model.DoctorName</dd>

                            <dt class="col-5 text-muted">Doctor ID</dt>
                            <dd class="col-7">#@Model.DoctorId</dd>

                            <dt class="col-5 text-muted">Bill Generated</dt>
                            <dd class="col-7">
                                @Model.GeneratedAt.ToString("dd MMM yyyy")
                            </dd>

                            @if (Model.PaidAt.HasValue)
                            {
                                <dt class="col-5 text-muted">Paid On</dt>
                                <dd class="col-7 text-success fw-semibold">
                                    @Model.PaidAt.Value.ToString("dd MMM yyyy")
                                </dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>

        </div>

        @* ── Itemised charges table ── *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header py-3" style="background-color: #f8f9ff;">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-list-ul me-2 text-primary"></i>Itemised Charges
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width:40px;">#</th>
                                <th>Description</th>
                                <th>Details</th>
                                <th class="text-end pe-4">Amount (₹)</th>
                            </tr>
                        </thead>
                        <tbody>

                            @* ── Row 1: Consultation fee ── *@
                            <tr class="table-primary bg-opacity-25">
                                <td class="ps-4 text-muted small">1</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-primary rounded-pill p-2">
                                            <i class="bi bi-person-badge"></i>
                                        </span>
                                        <div>
                                            <span class="fw-semibold d-block">Consultation Fee</span>
                                            <span class="text-muted small">
                                                Dr. @Model.DoctorName
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted small">
                                    Appointment #@Model.AppointmentId &bull;
                                    @Model.AppointmentDate.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-end pe-4 fw-semibold">
                                    ₹@Model.ConsultationFee.ToString("N2")
                                </td>
                            </tr>

                            @* ── Medicine line items ── *@
                            @if (Model.MedicineLines != null && Model.MedicineLines.Any())
                            {
                                var medIndex = 2;
                                foreach (var line in Model.MedicineLines)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted small">@medIndex</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-success rounded-pill p-2">
                                                    <i class="bi bi-capsule-pill"></i>
                                                </span>
                                                <div>
                                                    <span class="fw-semibold d-block">@line.MedicineName</span>
                                                    <span class="text-muted small">Medicine charge</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted small">
                                            @line.Dosage &bull; @line.Duration
                                        </td>
                                        <td class="text-end pe-4">
                                            ₹@line.Charge.ToString("N2")
                                        </td>
                                    </tr>
                                    medIndex++;
                                }
                            }
                            else if (Model.MedicineCharges == 0)
                            {
                                <tr>
                                    <td class="ps-4 text-muted small">2</td>
                                    <td colspan="2" class="text-muted fst-italic small">
                                        <i class="bi bi-dash-circle me-1"></i>
                                        No medicines prescribed for this appointment
                                    </td>
                                    <td class="text-end pe-4">₹0.00</td>
                                </tr>
                            }
                            else
                            {
                                @* Medicines were charged as a lump sum (no prescription breakdown) *@
                                <tr>
                                    <td class="ps-4 text-muted small">2</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-success rounded-pill p-2">
                                                <i class="bi bi-capsule"></i>
                                            </span>
                                            <span class="fw-semibold">Medicine Charges</span>
                                        </div>
                                    </td>
                                    <td class="text-muted small">Lump sum medicine charges</td>
                                    <td class="text-end pe-4">
                                        ₹@Model.MedicineCharges.ToString("N2")
                                    </td>
                                </tr>
                            }

                        </tbody>
                        <tfoot>

                            @* ── Subtotals and total ── *@
                            <tr class="table-light">
                                <td colspan="3" class="text-end pe-3 text-muted small fw-semibold">
                                    Consultation Sub-total
                                </td>
                                <td class="text-end pe-4 fw-semibold">
                                    ₹@Model.ConsultationFee.ToString("N2")
                                </td>
                            </tr>
                            <tr class="table-light">
                                <td colspan="3" class="text-end pe-3 text-muted small fw-semibold">
                                    Medicine Sub-total
                                </td>
                                <td class="text-end pe-4 fw-semibold">
                                    ₹@Model.MedicineCharges.ToString("N2")
                                </td>
                            </tr>
                            <tr class="table-success">
                                <td colspan="3" class="text-end pe-3 fw-bold fs-6">
                                    <i class="bi bi-calculator me-1"></i>TOTAL AMOUNT
                                </td>
                                <td class="text-end pe-4 fw-bold fs-5 text-success">
                                    ₹@Model.TotalAmount.ToString("N2")
                                </td>
                            </tr>

                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @* ── Notes section ── *@
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header py-2 bg-light">
                    <h6 class="mb-0 text-muted">
                        <i class="bi bi-journal-text me-2"></i>Notes
                    </h6>
                </div>
                <div class="card-body p-3">
                    <p class="mb-0 text-muted small" style="white-space: pre-wrap;">@Model.Notes</p>
                </div>
            </div>
        }

        @* ── Print footer ── *@
        <div class="card border-0 bg-light mb-4">
            <div class="card-body p-3 text-center text-muted small">
                <p class="mb-1">
                    <i class="bi bi-hospital me-1"></i>
                    <strong>SmartHealthCare Hospital</strong> &bull;
                    Thank you for choosing us for your healthcare needs.
                </p>
                <p class="mb-0">
                    This is a computer-generated bill and does not require a physical signature.
                    For queries, contact billing@smarthealthcare.com
                </p>
            </div>
        </div>

    </div>
    @* end #printableBill *@

</div>

@* ════════════════════════════════════════════════════════
     MODALS
   ════════════════════════════════════════════════════════ *@

@* Mark as Paid modal *@
@if ((isDoctor || isAdmin) && isUnpaid)
{
    <div class="modal fade" id="markPaidModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-success">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-check-circle-fill me-2"></i>Confirm Payment
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        Mark <strong>Bill #@Model.Id</strong> as paid?
                        Total amount: <strong class="text-success">₹@Model.TotalAmount.ToString("N2")</strong>
                    </p>
                    <label class="form-label small fw-semibold">
                        Payment Notes (optional)
                    </label>
                    <input type="text"
                           class="form-control form-control-sm"
                           id="paidNotesInput"
                           placeholder="e.g. Cash received, UPI transaction #..." />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <form asp-action="MarkAsPaid"
                          asp-controller="Billing"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="d-inline"
                          id="markPaidForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="notes" id="paidNotesHidden" />
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Confirm Payment
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* Waive modal *@
@if (isAdmin && isUnpaid)
{
    <div class="modal fade" id="waiveModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-slash-circle-fill me-2"></i>Waive Bill
                    </h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        Are you sure you want to waive <strong>Bill #@Model.Id</strong>
                        (₹@Model.TotalAmount.ToString("N2"))? The patient will not be charged.
                    </p>
                    <label class="form-label small fw-semibold">
                        Reason for waiving <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control form-control-sm"
                           id="waiveNotesInput"
                           placeholder="e.g. Financial hardship, insurance covered, admin error..." />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <form asp-action="Waive"
                          asp-controller="Billing"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="d-inline"
                          id="waiveForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="notes" id="waiveNotesHidden" />
                        <button type="submit" class="btn btn-warning text-dark fw-semibold">
                            <i class="bi bi-slash-circle me-1"></i>Waive Bill
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* Revert to Unpaid modal *@
@if (isAdmin && isPaid)
{
    <div class="modal fade" id="revertModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Revert Payment
                    </h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">
                        Revert <strong>Bill #@Model.Id</strong> back to
                        <strong>Unpaid</strong>? This will clear the payment record.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <form asp-action="MarkAsUnpaid"
                          asp-controller="Billing"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-warning text-dark fw-semibold">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Revert to Unpaid
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* Delete modal *@
@if (isAdmin)
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-trash3-fill me-2"></i>Delete Bill
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-1">
                        Permanently delete <strong>Bill #@Model.Id</strong>?
                    </p>
                    <p class="text-danger small mb-0">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        This cannot be undone. The appointment record will remain intact.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <form asp-action="Delete"
                          asp-controller="Billing"
                          asp-route-id="@Model.Id"
                          method="post"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash3 me-1"></i>Delete Bill
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* ── Print styles ── *@
<style>
    @@media print {
        .no-print,
        nav,
        footer,
        .alert,
        .modal {
            display: none !important;
        }

        #printableBill {
            margin: 0;
            padding: 0;
        }

        .card {
            border: 1px solid #dee2e6 !important;
            box-shadow: none !important;
            break-inside: avoid;
        }

        .card-header {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .table-success,
        .table-primary,
        .table-light {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        body {
            font-size: 12px;
        }
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Copy the notes input into the hidden field before
            // the Mark as Paid form submits so the value is POSTed
            $('#markPaidForm').closest('.modal').on('hide.bs.modal', function () {
                // Don't clear on cancel — only on submit
            });

            // Wire up notes inputs to their hidden counterparts
            $('#markPaidModal').on('show.bs.modal', function () {
                $('#paidNotesInput').val('');
            });

            $('#markPaidForm').on('submit', function () {
                $('#paidNotesHidden').val($('#paidNotesInput').val());
            });

            $('#waiveForm').on('submit', function () {
                $('#waiveNotesHidden').val($('#waiveNotesInput').val());
            });

        });
    </script>
}