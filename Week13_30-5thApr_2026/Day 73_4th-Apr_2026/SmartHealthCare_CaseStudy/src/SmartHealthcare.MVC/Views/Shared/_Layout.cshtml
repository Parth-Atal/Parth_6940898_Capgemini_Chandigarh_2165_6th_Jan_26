<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>

:root{
    --bg:#f6f9ff;
    --card:#ffffff;
    --border:#e6ecff;

    --text:#0f172a;
    --muted:#64748b;

    --cyan:#06b6d4;
    --violet:#6366f1;
    --pink:#ec4899;
}

/* GLOBAL */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:linear-gradient(135deg,#f8fbff,#eef3ff);
    color:var(--text);
    font-family:'Inter',sans-serif;
}

/* NAVBAR */
.navbar{
    backdrop-filter:blur(16px);
    background:rgba(255,255,255,0.85);
    border-bottom:1px solid var(--border);
    padding:14px 0;
}

.navbar-brand{
    font-weight:800;
    font-size:20px;
    background:linear-gradient(90deg,var(--violet),var(--cyan));
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.nav-link{
    color:var(--muted) !important;
    font-weight:500;
    transition:.3s;
}

.nav-link:hover{
    color:var(--text) !important;
}

/* BUTTONS */
.btn-primary{
    background:linear-gradient(135deg,var(--violet),var(--cyan));
    border:none;
    border-radius:12px;
    padding:10px 18px;
    font-weight:600;
    color:white;
    transition:.3s;
}

.btn-primary:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 25px rgba(99,102,241,.3);
}

.btn-outline{
    border:1px solid var(--border);
    border-radius:12px;
    padding:10px 18px;
    color:var(--muted);
    background:white;
}

.btn-outline:hover{
    background:#f1f5ff;
}

/* MAIN */
.main{
    padding:40px 0;
}

/* CARD BASE */
.card{
    background:var(--card);
    border:1px solid var(--border);
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.05);
}

/* ALERTS */
.alert{
    border-radius:12px;
    border:none;
}

.alert-success{
    background:#ecfdf5;
    color:#065f46;
}

.alert-danger{
    background:#fef2f2;
    color:#7f1d1d;
}

/* FOOTER */
.footer{
    margin-top:60px;
    padding:20px;
    text-align:center;
    color:var(--muted);
    border-top:1px solid var(--border);
    background:white;
}

/* CONTAINER SPACING FIX */
.container{
    max-width:1200px;
}

/* SMALL POLISH */
.text-muted{
    color:var(--muted) !important;
}

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg">
    <div class="container">

        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fa-solid fa-hospital"></i> Smart Healthcare
        </a>

        <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav"></button>

        <div class="collapse navbar-collapse" id="nav">

            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Index">Doctors</a></li>

                @if (Context.Session.GetString("Token") != null)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointments</a></li>

                    @if (Context.Session.GetString("Role") == "Doctor")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Doctor" asp-action="Profile">Profile</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Patient" asp-action="Profile">Profile</a></li>
                    }
                }
            </ul>

            <div class="d-flex align-items-center gap-2">

                @if (Context.Session.GetString("Token") != null)
                {
                    <span class="text-muted small">@Context.Session.GetString("FullName")</span>
                    <a class="btn btn-outline" asp-controller="Account" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-outline" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Register</a>
                }

            </div>

        </div>
    </div>
</nav>

<div class="main">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @RenderBody()

    </div>
</div>

<div class="footer">
    © 2026 Smart Healthcare • Intelligent Care Platform
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>