@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string;
    var fullName = ViewBag.FullName as string;
}

<div class="dashboard">

    <div class="container-main">

        <!-- HERO -->
        <div class="hero fade-in">
            <div class="hero-content">
                <h1>Welcome back, <span>@fullName</span></h1>
                <p>Your Smart Healthcare Command Center</p>
                <div class="role-badge">@role</div>
            </div>

            <div class="hero-decoration"></div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">

            <div class="stat-card">
                <div class="icon">👥</div>
                <div>
                    <p>Users</p>
                    <h2>1,204</h2>
                </div>
            </div>

            <div class="stat-card">
                <div class="icon">🩺</div>
                <div>
                    <p>Doctors</p>
                    <h2>320</h2>
                </div>
            </div>

            <div class="stat-card">
                <div class="icon">📅</div>
                <div>
                    <p>Appointments</p>
                    <h2>842</h2>
                </div>
            </div>

            <div class="stat-card">
                <div class="icon">💊</div>
                <div>
                    <p>Prescriptions</p>
                    <h2>2,421</h2>
                </div>
            </div>

        </div>

        <!-- ACTIONS -->
        <div class="action-grid">

            @if (role == "Admin")
            {
                <a href="@Url.Action("Users","Admin")" class="action-card blue">
                    <h3>Manage Users</h3>
                    <p>Control system users</p>
                </a>

                <a href="@Url.Action("Index","Doctor")" class="action-card green">
                    <h3>Doctors</h3>
                    <p>View & manage doctors</p>
                </a>

                <a href="@Url.Action("Index","Appointment")" class="action-card pink">
                    <h3>Appointments</h3>
                    <p>Track schedules</p>
                </a>
            }

            @if (role == "Doctor")
            {
                <a href="@Url.Action("Index","Appointment")" class="action-card blue">
                    <h3>My Appointments</h3>
                </a>

                <a href="@Url.Action("Profile","Doctor")" class="action-card green">
                    <h3>Profile</h3>
                </a>
            }

            @if (role == "Patient")
            {
                <a href="@Url.Action("Create","Appointment")" class="action-card blue">
                    <h3>Book Appointment</h3>
                </a>

                <a href="@Url.Action("Index","Doctor")" class="action-card green">
                    <h3>Find Doctor</h3>
                </a>
            }

        </div>

    </div>

</div>

<style>

:root{
    --bg:#f6f9ff;
    --card:#ffffff;
    --border:#e6ecff;

    --text:#0f172a;
    --muted:#64748b;

    --cyan:#06b6d4;
    --violet:#6366f1;
    --pink:#ec4899;
    --green:#22c55e;
}

body{
    background:linear-gradient(135deg,#f8fbff,#eef3ff);
    font-family:'Inter',sans-serif;
    color:var(--text);
}

.container-main{
    padding:50px 40px;
}

/* HERO */
.hero{
    position:relative;
    padding:40px;
    border-radius:24px;
    background:linear-gradient(135deg,#ffffff,#eef2ff);
    border:1px solid var(--border);
    box-shadow:0 20px 50px rgba(0,0,0,.05);
    margin-bottom:40px;
    overflow:hidden;
}

.hero h1{
    font-size:2.5rem;
    font-weight:900;
}

.hero h1 span{
    background:linear-gradient(90deg,var(--violet),var(--cyan));
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.hero p{
    color:var(--muted);
    margin:10px 0;
}

.role-badge{
    display:inline-block;
    padding:6px 14px;
    border-radius:20px;
    background:linear-gradient(135deg,var(--violet),var(--cyan));
    color:white;
    font-size:12px;
}

.hero-decoration{
    position:absolute;
    width:200px;
    height:200px;
    background:radial-gradient(circle,var(--cyan),transparent);
    right:-50px;
    top:-50px;
    opacity:.3;
}

/* STATS */
.stats-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
    margin-bottom:40px;
}

.stat-card{
    display:flex;
    gap:15px;
    padding:20px;
    border-radius:20px;
    background:white;
    border:1px solid var(--border);
    box-shadow:0 10px 25px rgba(0,0,0,.05);
    transition:.3s;
}

.stat-card:hover{
    transform:translateY(-6px) scale(1.02);
}

.icon{
    font-size:26px;
}

/* ACTIONS */
.action-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.action-card{
    padding:30px;
    border-radius:20px;
    background:white;
    border:1px solid var(--border);
    text-decoration:none;
    color:var(--text);
    transition:.3s;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
    position:relative;
    overflow:hidden;
}

.action-card:hover{
    transform:translateY(-8px) scale(1.03);
}

/* COLOR VARIANTS */
.action-card.blue:hover{
    box-shadow:0 15px 35px rgba(6,182,212,.3);
}

.action-card.green:hover{
    box-shadow:0 15px 35px rgba(34,197,94,.3);
}

.action-card.pink:hover{
    box-shadow:0 15px 35px rgba(236,72,153,.3);
}

/* ANIMATION */
.fade-in{
    animation:fadeIn .6s ease;
}

@@keyframes fadeIn{
    from{opacity:0;transform:translateY(20px);}
    to{opacity:1;transform:translateY(0);}
}

</style>