@model SmartHealthcare.Models.DTOs.PagedResult<SmartHealthcare.Models.DTOs.DoctorDTO>
@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="container-main">

    <div class="header">
        <h1>Find a Doctor</h1>
        <p>Search and connect with top medical professionals</p>
    </div>

    <div class="search-card">
        <form method="get" class="search-form">
            <div class="field">
                <label>Specialization</label>
                <input type="text" name="specialization" value="@ViewBag.Specialization" placeholder="Cardiology, Dermatology" />
            </div>

            <div class="field">
                <label>Doctor Name</label>
                <input type="text" name="name" value="@ViewBag.Name" placeholder="Doctor name" />
            </div>

            <button type="submit" class="btn-primary">Search</button>
        </form>
    </div>

    @if (Model?.Items != null && Model.Items.Any())
    {
        <div class="grid">

            @foreach (var doctor in Model.Items)
            {
                <div class="card">

                    <div class="card-top">
                        <div>
                            <h3>Dr. @doctor.FullName</h3>
                            <p>@string.Join(" • ", doctor.Specializations ?? new List<string>())</p>
                        </div>

                        <span class="status @(doctor.IsAvailable ? "available" : "unavailable")">
                            @(doctor.IsAvailable ? "Available" : "Unavailable")
                        </span>
                    </div>

                    <div class="info">
                        <p><span>Email:</span> @doctor.Email</p>
                        <p><span>Phone:</span> @doctor.Phone</p>
                        <p><span>Experience:</span> @doctor.YearsOfExperience yrs</p>
                        <p><span>Fee:</span> ₹@doctor.ConsultationFee</p>
                    </div>

                    <div class="actions">
                        <a asp-action="Details" asp-route-id="@doctor.Id" class="btn-secondary">View</a>

                        @if (doctor.IsAvailable)
                        {
                            <a asp-controller="Appointment" asp-action="Create" class="btn-primary">Book</a>
                        }
                    </div>

                </div>
            }

        </div>

        @if (Model.PageNumber > 1 || Model.Items.Count() == Model.PageSize)
        {
            <div class="pagination">

                @if (Model.PageNumber > 1)
                {
                    <a href="?page=1&specialization=@ViewBag.Specialization&name=@ViewBag.Name">First</a>
                    <a href="?page=@(Model.PageNumber - 1)&specialization=@ViewBag.Specialization&name=@ViewBag.Name">Prev</a>
                }

                <span>Page @Model.PageNumber</span>

                @if (Model.PageNumber * 10 < Model.TotalCount)
                {
                    <a href="?page=@(Model.PageNumber + 1)&specialization=@ViewBag.Specialization&name=@ViewBag.Name">Next</a>
                }

            </div>
        }
    }
    else
    {
        <div class="empty">
            <h3>No Doctors Found</h3>
            <p>Try adjusting your search</p>
            <a href="@Url.Action("Index")" class="btn-secondary">Reset</a>
        </div>
    }

</div>

<style>

:root{
    --bg:#f6f9ff;
    --card:#ffffff;
    --border:#e6ecff;

    --text:#0f172a;
    --muted:#64748b;

    --cyan:#06b6d4;
    --violet:#6366f1;
}

body{
    background:linear-gradient(135deg,#f8fbff,#eef3ff);
    color:var(--text);
    font-family:'Inter',sans-serif;
}

.container-main{
    padding:50px 40px;
}

/* HEADER */
.header{
    margin-bottom:30px;
}

.header h1{
    font-size:2rem;
    font-weight:800;
    background:linear-gradient(90deg,var(--violet),var(--cyan));
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.header p{
    color:var(--muted);
}

/* SEARCH */
.search-card{
    background:white;
    border:1px solid var(--border);
    border-radius:20px;
    padding:20px;
    margin-bottom:30px;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.search-form{
    display:flex;
    gap:15px;
    flex-wrap:wrap;
}

.field{
    flex:1;
    display:flex;
    flex-direction:column;
    gap:5px;
}

.field label{
    font-size:12px;
    color:var(--muted);
}

.field input{
    padding:12px;
    border-radius:10px;
    border:1px solid var(--border);
    background:white;
    color:var(--text);
}

.field input:focus{
    border-color:var(--violet);
    outline:none;
    box-shadow:0 0 0 2px rgba(99,102,241,.15);
}

/* GRID */
.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

/* CARD */
.card{
    background:white;
    border:1px solid var(--border);
    border-radius:20px;
    padding:20px;
    transition:.3s;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card:hover{
    transform:translateY(-6px);
}

/* TOP */
.card-top{
    display:flex;
    justify-content:space-between;
    margin-bottom:10px;
}

.card-top p{
    color:var(--muted);
}

/* STATUS */
.status{
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    font-weight:600;
}

.available{
    background:#dcfce7;
    color:#166534;
}

.unavailable{
    background:#fee2e2;
    color:#991b1b;
}

/* INFO */
.info p{
    margin:5px 0;
}

.info span{
    color:var(--muted);
}

/* BUTTONS */
.actions{
    display:flex;
    gap:10px;
    margin-top:10px;
}

.btn-primary{
    flex:1;
    text-align:center;
    padding:10px;
    border-radius:10px;
    background:linear-gradient(135deg,var(--violet),var(--cyan));
    color:white;
    text-decoration:none;
    font-weight:600;
}

.btn-primary:hover{
    transform:translateY(-2px);
    box-shadow:0 10px 20px rgba(99,102,241,.3);
}

.btn-secondary{
    flex:1;
    text-align:center;
    padding:10px;
    border-radius:10px;
    border:1px solid var(--border);
    color:var(--muted);
    text-decoration:none;
    background:white;
}

.btn-secondary:hover{
    background:#f1f5ff;
}

/* PAGINATION */
.pagination{
    margin-top:20px;
    display:flex;
    justify-content:center;
    gap:10px;
}

.pagination a{
    padding:8px 12px;
    border-radius:10px;
    border:1px solid var(--border);
    color:var(--muted);
    text-decoration:none;
    background:white;
}

.pagination a:hover{
    background:#eef2ff;
}

/* EMPTY */
.empty{
    text-align:center;
    padding:40px;
    background:white;
    border-radius:20px;
    border:1px solid var(--border);
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

</style>