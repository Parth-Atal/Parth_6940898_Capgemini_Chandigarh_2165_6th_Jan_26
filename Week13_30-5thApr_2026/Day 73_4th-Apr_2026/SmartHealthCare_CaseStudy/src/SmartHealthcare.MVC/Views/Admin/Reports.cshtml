@{
    ViewData["Title"] = "Admin Reports";
}

<div class="reports-scene">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>

    <div class="reports-shell">

        <div class="page-header">
            <div class="page-header-left">
                <span class="page-eyebrow">
                    <span class="eyebrow-dot"></span>
                    Live Data
                </span>
                <h1 class="page-title">Analytics &amp; Reports</h1>
                <p class="page-subtitle">System statistics and performance metrics</p>
            </div>
            <div class="page-header-right">
                <div class="timestamp-pill">
                    <svg viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                    </svg>
                    @DateTime.Now.ToString("dd MMM yyyy · HH:mm")
                </div>
            </div>
        </div>

        @if (ViewBag.Report != null)
        {
            <section class="section">
                <div class="section-label">
                    <svg viewBox="0 0 16 16" fill="none">
                        <path d="M2 12h2V8H2v4zm4 0h2V4H6v8zm4 0h2V6h-2v6z" fill="currentColor"/>
                    </svg>
                    Overview
                </div>
                <div class="stats-grid stats-grid-4">
                    <div class="stat-card" style="--accent:#00E5FF;--delay:0.05s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(0,229,255,0.12);--icon-color:#00E5FF">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <path d="M9 11a4 4 0 100-8 4 4 0 000 8zm8 6a8 8 0 10-16 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <path d="M15 14v4M13 16h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="stat-trend stat-trend-up">+12%</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).TotalUsers</div>
                        <div class="stat-label">Total Users</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:78%"></div></div>
                    </div>

                    <div class="stat-card" style="--accent:#00FFA3;--delay:0.1s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(0,255,163,0.12);--icon-color:#00FFA3">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M3 17c0-3.3 3.1-6 7-6s7 2.7 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="stat-trend stat-trend-up">+8%</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).TotalPatients</div>
                        <div class="stat-label">Total Patients</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:62%"></div></div>
                    </div>

                    <div class="stat-card" style="--accent:#7B2FF7;--delay:0.15s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(123,47,247,0.15);--icon-color:#a06aff">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <path d="M10 2a4 4 0 014 4v1a4 4 0 01-8 0V6a4 4 0 014-4z" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M4 18v-1a6 6 0 0112 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <path d="M14 10h3M15.5 8.5v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="stat-trend stat-trend-up">+5%</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).TotalDoctors</div>
                        <div class="stat-label">Total Doctors</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:45%"></div></div>
                    </div>

                    <div class="stat-card" style="--accent:#FFB830;--delay:0.2s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(255,184,48,0.12);--icon-color:#FFB830">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <rect x="3" y="4" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M7 2v4M13 2v4M3 9h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <path d="M7 13h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="stat-trend stat-trend-up">+19%</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).TotalAppointments</div>
                        <div class="stat-label">Total Appointments</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:88%"></div></div>
                    </div>
                </div>
            </section>

            <section class="section">
                <div class="section-label">
                    <svg viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                    </svg>
                    Appointment Breakdown
                </div>
                <div class="stats-grid stats-grid-3">
                    <div class="stat-card stat-card-accent" style="--accent:#FFB830;--accent-soft:rgba(255,184,48,0.1);--delay:0.25s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(255,184,48,0.15);--icon-color:#FFB830">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="status-chip status-pending">Pending</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).PendingAppointments</div>
                        <div class="stat-label">Awaiting confirmation</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:55%"></div></div>
                    </div>

                    <div class="stat-card stat-card-accent" style="--accent:#00FFA3;--accent-soft:rgba(0,255,163,0.1);--delay:0.3s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(0,255,163,0.15);--icon-color:#00FFA3">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M6.5 10.5l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <span class="status-chip status-completed">Completed</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).CompletedAppointments</div>
                        <div class="stat-label">Successfully concluded</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:72%"></div></div>
                    </div>

                    <div class="stat-card stat-card-accent" style="--accent:#FF4757;--accent-soft:rgba(255,71,87,0.1);--delay:0.35s">
                        <div class="stat-card-top">
                            <div class="stat-icon" style="--icon-bg:rgba(255,71,87,0.15);--icon-color:#FF4757">
                                <svg viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M7 7l6 6M13 7l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <span class="status-chip status-cancelled">Cancelled</span>
                        </div>
                        <div class="stat-value">@((dynamic)ViewBag.Report).CancelledAppointments</div>
                        <div class="stat-label">No longer active</div>
                        <div class="stat-bar"><div class="stat-bar-fill" style="width:18%"></div></div>
                    </div>
                </div>
            </section>

            <section class="section">
                <div class="section-label">
                    <svg viewBox="0 0 16 16" fill="none">
                        <path d="M4 2h8l1 3H3L4 2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                        <rect x="2" y="5" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M8 8v3M6.5 9.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    Prescriptions
                </div>
                <div class="rx-card">
                    <div class="rx-left">
                        <div class="rx-icon">
                            <svg viewBox="0 0 28 28" fill="none">
                                <path d="M6 4h16l2 5H4L6 4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                                <rect x="3" y="9" width="22" height="15" rx="2.5" stroke="currentColor" stroke-width="1.6"/>
                                <path d="M14 14v6M11 17h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div>
                            <div class="rx-title">Total Prescriptions Issued</div>
                            <div class="rx-desc">Across all completed appointments</div>
                        </div>
                    </div>
                    <div class="rx-value">@((dynamic)ViewBag.Report).TotalPrescriptions</div>
                </div>
            </section>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <svg viewBox="0 0 40 40" fill="none">
                        <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M20 13v8M20 25v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="empty-title">No Reports Available</div>
                <div class="empty-desc">Report data could not be loaded at this time. Please try again later.</div>
            </div>
        }

    </div>
</div>

<style>
@@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --cyan:   #00E5FF;
    --violet: #7B2FF7;
    --green:  #00FFA3;
    --amber:  #FFB830;
    --dark:   #080B14;
    --dark2:  #0E1220;
    --dark3:  #141929;
    --glass:  rgba(255,255,255,0.04);
    --glass2: rgba(255,255,255,0.07);
    --border: rgba(255,255,255,0.08);
    --text:   #E8EEFF;
    --muted:  rgba(200,210,255,0.5);
    --font-display: 'Syne', sans-serif;
    --font-body:    'DM Sans', sans-serif;
}

body {
    background: var(--dark);
    color: var(--text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
}

.reports-scene {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 2rem;
}

.orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
}
.orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--violet) 0%, transparent 70%);
    top: -150px; right: -100px;
    opacity: 0.3;
    animation: driftA 22s ease-in-out infinite alternate;
}
.orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--cyan) 0%, transparent 70%);
    bottom: -100px; left: -80px;
    opacity: 0.2;
    animation: driftB 28s ease-in-out infinite alternate;
}
.orb-3 {
    width: 250px; height: 250px;
    background: radial-gradient(circle, var(--green) 0%, transparent 70%);
    top: 50%; left: 40%;
    opacity: 0.1;
    animation: driftC 18s ease-in-out infinite alternate;
}

@@keyframes driftA {
    from { transform: translate(0,0); }
    to   { transform: translate(-50px, 70px); }
}
@@keyframes driftB {
    from { transform: translate(0,0); }
    to   { transform: translate(60px, -60px); }
}
@@keyframes driftC {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(-40px, 40px) scale(1.2); }
}

.grid-overlay {
    position: fixed; inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black 20%, transparent 100%);
}

.reports-shell {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-bottom: 3rem;
}

.page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-top: 0.5rem;
    animation: fadeUp 0.6s ease both;
}

.page-header-left {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}

.page-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
}

.eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    animation: blink 2s ease-in-out infinite;
}

@@keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
}

.page-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.1;
}

.page-subtitle {
    font-size: 0.88rem;
    color: var(--muted);
}

.timestamp-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--glass2);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.45rem 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
}
.timestamp-pill svg { width: 14px; height: 14px; color: var(--cyan); }

.section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: fadeUp 0.6s ease both;
    animation-delay: var(--s-delay, 0.1s);
}

.section:nth-child(2) { --s-delay: 0.1s; }
.section:nth-child(3) { --s-delay: 0.2s; }
.section:nth-child(4) { --s-delay: 0.3s; }

.section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
}
.section-label svg { width: 13px; height: 13px; }

.stats-grid {
    display: grid;
    gap: 1rem;
}
.stats-grid-4 { grid-template-columns: repeat(4, 1fr); }
.stats-grid-3 { grid-template-columns: repeat(3, 1fr); }

.stat-card {
    background: var(--glass2);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0s);
    cursor: default;
}

.stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(var(--accent-rgb, 0,229,255), 0.04) 0%, transparent 60%);
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
}

.stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--accent-rgb,255,255,255), 0.2);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 0 1px color-mix(in srgb, var(--accent) 20%, transparent);
}

.stat-card:hover::before { opacity: 1; }

.stat-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
}

.stat-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: var(--icon-bg);
    color: var(--icon-color);
    display: grid; place-items: center;
    flex-shrink: 0;
}
.stat-icon svg { width: 18px; height: 18px; }

.stat-trend {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
}

.stat-trend-up {
    background: rgba(0,255,163,0.12);
    color: var(--green);
    border: 1px solid rgba(0,255,163,0.2);
}

.stat-trend-down {
    background: rgba(255,71,87,0.12);
    color: #FF4757;
    border: 1px solid rgba(255,71,87,0.2);
}

.status-chip {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
}

.status-pending   { background: rgba(255,184,48,0.15);  color: #FFB830; border: 1px solid rgba(255,184,48,0.25); }
.status-completed { background: rgba(0,255,163,0.12);   color: #00FFA3; border: 1px solid rgba(0,255,163,0.2); }
.status-cancelled { background: rgba(255,71,87,0.12);   color: #FF4757; border: 1px solid rgba(255,71,87,0.2); }

.stat-value {
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.25rem;
}

.stat-label {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 400;
    margin-bottom: 0.6rem;
}

.stat-bar {
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
    margin-top: auto;
}

.stat-bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    animation: barGrow 1s cubic-bezier(0.22,1,0.36,1) both;
    animation-delay: calc(var(--delay, 0s) + 0.3s);
    transform-origin: left;
}

@@keyframes barGrow {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
}

.rx-card {
    background: var(--glass2);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.6rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease;
    animation: fadeUp 0.5s 0.35s ease both;
}

.rx-card:hover {
    transform: translateY(-3px);
    border-color: rgba(0,229,255,0.2);
    box-shadow: 0 12px 40px rgba(0,0,0,0.25);
}

.rx-left {
    display: flex;
    align-items: center;
    gap: 1.1rem;
}

.rx-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: rgba(0,229,255,0.1);
    color: var(--cyan);
    display: grid; place-items: center;
    flex-shrink: 0;
}
.rx-icon svg { width: 26px; height: 26px; }

.rx-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
}

.rx-desc {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.2rem;
}

.rx-value {
    font-family: var(--font-display);
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--cyan);
    letter-spacing: -0.03em;
    line-height: 1;
    text-shadow: 0 0 30px rgba(0,229,255,0.3);
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 5rem 2rem;
    text-align: center;
    animation: fadeUp 0.6s ease both;
}

.empty-icon {
    width: 72px; height: 72px;
    border-radius: 20px;
    background: rgba(255,184,48,0.1);
    border: 1px solid rgba(255,184,48,0.2);
    display: grid; place-items: center;
    color: var(--amber);
}
.empty-icon svg { width: 36px; height: 36px; }

.empty-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
}

.empty-desc {
    font-size: 0.85rem;
    color: var(--muted);
    max-width: 320px;
    line-height: 1.6;
}

@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}

@@media (max-width: 1024px) {
    .stats-grid-4 { grid-template-columns: repeat(2, 1fr); }
    .stats-grid-3 { grid-template-columns: repeat(2, 1fr); }
}

@@media (max-width: 640px) {
    .reports-scene { padding: 1.25rem; }
    .stats-grid-4,
    .stats-grid-3 { grid-template-columns: 1fr; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-title { font-size: 1.7rem; }
    .stat-value { font-size: 2rem; }
    .rx-card { flex-direction: column; align-items: flex-start; }
    .rx-value { font-size: 2.4rem; }
}
</style>
