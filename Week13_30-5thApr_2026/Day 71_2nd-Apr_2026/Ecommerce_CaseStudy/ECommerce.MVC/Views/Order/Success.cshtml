<!DOCTYPE html>
<html>
<head>
    <title>Success</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #00c9a7, #845ec2);
        }

        .card {
            width: 360px;
            padding: 45px 30px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(15px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.2);
            text-align: center;
            color: #fff;
            animation: fadeIn 0.7s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .checkmark {
            font-size: 50px;
            margin-bottom: 15px;
            animation: pop 0.5s ease;
        }

        @@keyframes pop {
            0% { transform: scale(0); }
            80% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

        h2 {
            margin-bottom: 20px;
            font-weight: 600;
        }

        p {
            font-size: 13px;
            opacity: 0.85;
            margin-bottom: 20px;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        a {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: 0.3s;
            text-align: center;
        }

        .primary {
            background: #ffffff;
            color: #333;
        }

        .primary:hover {
            background: #f1f1f1;
            transform: translateY(-2px);
        }

        .secondary {
            background: rgba(255,255,255,0.25);
            color: #fff;
        }

        .secondary:hover {
            background: rgba(255,255,255,0.35);
            transform: translateY(-2px);
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="checkmark">✅</div>

        <h2>Order Placed!</h2>
        <p>Your order has been successfully created.</p>

        <div class="btn-group">
            <a href="/Order/Index" class="primary">View Orders</a>
            <a href="/Order/Create" class="secondary">New Order</a>
        </div>
    </div>
</body>
</html>