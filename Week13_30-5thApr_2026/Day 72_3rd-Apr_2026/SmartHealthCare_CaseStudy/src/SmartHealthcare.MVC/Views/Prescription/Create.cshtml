@model SmartHealthcare.Models.DTOs.CreatePrescriptionDTO

@{
    ViewData["Title"] = "Write Prescription";
    var appointment = ViewBag.Appointment as SmartHealthcare.Models.DTOs.AppointmentDTO;
}

<div class="container py-4">

    @* ── Page header ── *@
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-1 fw-semibold text-primary">
                <i class="bi bi-file-earmark-medical me-2"></i>Write Prescription
            </h2>
            @if (appointment != null)
            {
                <p class="text-muted mb-0">
                    Appointment #@appointment.Id &mdash;
                    Patient: <strong>@appointment.PatientName</strong> &mdash;
                    Date: <strong>@appointment.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</strong>
                </p>
            }
        </div>
        <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentId"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Appointment
        </a>
    </div>

    @* ── Alert messages ── *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Please fix the errors below before submitting.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Create" asp-controller="Prescription" method="post" id="prescriptionForm">
        @Html.AntiForgeryToken()

        @* Hidden field to carry the appointment ID through the form *@
        <input type="hidden" asp-for="AppointmentId" />

        <div class="row g-4">

            @* ── Left column: Diagnosis & Notes ── *@
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0">
                            <i class="bi bi-clipboard2-pulse me-2"></i>Clinical Details
                        </h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="mb-4">
                            <label asp-for="Diagnosis" class="form-label fw-semibold">
                                Diagnosis <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Diagnosis"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Enter the patient's diagnosis in detail..."
                                      id="diagnosisField"></textarea>
                            <span asp-validation-for="Diagnosis" class="text-danger small"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Notes" class="form-label fw-semibold">
                                Additional Notes
                                <span class="text-muted fw-normal">(optional)</span>
                            </label>
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Any follow-up instructions, lifestyle advice, referrals..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                    </div>
                </div>
            </div>

            @* ── Right column: Medicines ── *@
            <div class="col-lg-7">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white py-3 d-flex align-items-center justify-content-between">
                        <h5 class="mb-0">
                            <i class="bi bi-capsule me-2"></i>Prescribed Medicines
                        </h5>
                        <button type="button" class="btn btn-light btn-sm fw-semibold" id="addMedicineBtn">
                            <i class="bi bi-plus-circle me-1"></i>Add Medicine
                        </button>
                    </div>
                    <div class="card-body p-4">

                        <p class="text-muted small mb-3">
                            Fill in each medicine row below. Use the red button to remove a row.
                            At least one medicine is recommended.
                        </p>

                        @* ── Medicine rows container ── *@
                        <div id="medicinesContainer">
                            @for (int i = 0; i < Model.Medicines.Count; i++)
                            {
                                <div class="medicine-row card border mb-3" data-index="@i">
                                    <div class="card-body p-3">

                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="fw-semibold text-success medicine-label">
                                                <i class="bi bi-capsule-pill me-1"></i>Medicine @(i + 1)
                                            </span>
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm remove-medicine-btn"
                                                    title="Remove this medicine">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small fw-semibold">
                                                    Medicine Name <span class="text-danger">*</span>
                                                </label>
                                                <input type="text"
                                                       name="Medicines[@i].Name"
                                                       value="@Model.Medicines[i].Name"
                                                       class="form-control form-control-sm medicine-name"
                                                       placeholder="e.g. Paracetamol 500mg"
                                                       required />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-semibold">
                                                    Dosage <span class="text-danger">*</span>
                                                </label>
                                                <input type="text"
                                                       name="Medicines[@i].Dosage"
                                                       value="@Model.Medicines[i].Dosage"
                                                       class="form-control form-control-sm"
                                                       placeholder="e.g. 1 tablet twice daily"
                                                       required />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-semibold">
                                                    Duration <span class="text-danger">*</span>
                                                </label>
                                                <input type="text"
                                                       name="Medicines[@i].Duration"
                                                       value="@Model.Medicines[i].Duration"
                                                       class="form-control form-control-sm"
                                                       placeholder="e.g. 5 days"
                                                       required />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-semibold">
                                                    Instructions
                                                    <span class="text-muted fw-normal">(optional)</span>
                                                </label>
                                                <input type="text"
                                                       name="Medicines[@i].Instructions"
                                                       value="@Model.Medicines[i].Instructions"
                                                       class="form-control form-control-sm"
                                                       placeholder="e.g. Take after meals" />
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>

                        @* ── Empty state shown when no medicines are added ── *@
                        <div id="noMedicinesMessage" class="text-center text-muted py-4" style="display:none;">
                            <i class="bi bi-capsule fs-2 d-block mb-2 text-secondary"></i>
                            No medicines added yet. Click <strong>Add Medicine</strong> to begin.
                        </div>

                    </div>
                </div>
            </div>

        </div>

        @* ── Form action buttons ── *@
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-controller="Appointment"
               asp-action="Details"
               asp-route-id="@Model.AppointmentId"
               class="btn btn-outline-secondary btn-lg px-4">
                <i class="bi bi-x-circle me-2"></i>Cancel
            </a>
            <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                <i class="bi bi-check2-circle me-2"></i>Save Prescription
            </button>
        </div>

    </form>

</div>

@* ── Hidden template for a new empty medicine row, cloned by jQuery ── *@
<template id="medicineRowTemplate">
    <div class="medicine-row card border mb-3" data-index="__INDEX__">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-semibold text-success medicine-label">
                    <i class="bi bi-capsule-pill me-1"></i>Medicine __NUMBER__
                </span>
                <button type="button"
                        class="btn btn-outline-danger btn-sm remove-medicine-btn"
                        title="Remove this medicine">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">
                        Medicine Name <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           name="Medicines[__INDEX__].Name"
                           class="form-control form-control-sm medicine-name"
                           placeholder="e.g. Paracetamol 500mg"
                           required />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">
                        Dosage <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           name="Medicines[__INDEX__].Dosage"
                           class="form-control form-control-sm"
                           placeholder="e.g. 1 tablet twice daily"
                           required />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">
                        Duration <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           name="Medicines[__INDEX__].Duration"
                           class="form-control form-control-sm"
                           placeholder="e.g. 5 days"
                           required />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">
                        Instructions
                        <span class="text-muted fw-normal">(optional)</span>
                    </label>
                    <input type="text"
                           name="Medicines[__INDEX__].Instructions"
                           class="form-control form-control-sm"
                           placeholder="e.g. Take after meals" />
                </div>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {

            // ── Keep track of the next index for new medicine rows
            // We always increment and never reuse, so ASP.NET model binding
            // gets clean sequential indices even after rows are removed
            let nextIndex = @Model.Medicines.Count;

            // ── Utility: update the visible "Medicine N" labels after any add/remove
            function reNumberMedicineLabels() {
                $('#medicinesContainer .medicine-row').each(function (i) {
                    $(this).find('.medicine-label').html(
                        '<i class="bi bi-capsule-pill me-1"></i>Medicine ' + (i + 1)
                    );
                });
            }

            // ── Utility: show/hide the empty state message
            function updateEmptyState() {
                const count = $('#medicinesContainer .medicine-row').length;
                if (count === 0) {
                    $('#noMedicinesMessage').show();
                } else {
                    $('#noMedicinesMessage').hide();
                }
            }

            // ── Kick off with correct initial state
            reNumberMedicineLabels();
            updateEmptyState();

            // ── Add Medicine button
            $('#addMedicineBtn').on('click', function () {
                const template = document.getElementById('medicineRowTemplate');
                let html = template.innerHTML;

                // Swap the placeholders with the real index and display number
                html = html.replaceAll('__INDEX__', nextIndex);
                html = html.replaceAll('__NUMBER__', nextIndex + 1);

                $('#medicinesContainer').append(html);
                nextIndex++;

                reNumberMedicineLabels();
                updateEmptyState();

                // Scroll the new row into view smoothly
                const newRow = $('#medicinesContainer .medicine-row').last();
                newRow[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                // Focus the name field of the newly added row
                newRow.find('.medicine-name').focus();
            });

            // ── Remove Medicine button (delegated because rows are added dynamically)
            $('#medicinesContainer').on('click', '.remove-medicine-btn', function () {
                const row = $(this).closest('.medicine-row');

                // Animate the removal for a polished feel
                row.fadeOut(200, function () {
                    row.remove();
                    reNumberMedicineLabels();
                    updateEmptyState();
                });
            });

            // ── Form submission guard
            // Warn the doctor if they are about to submit with no medicines at all
            $('#prescriptionForm').on('submit', function (e) {
                const medicineCount = $('#medicinesContainer .medicine-row').length;

                if (medicineCount === 0) {
                    const confirmed = confirm(
                        'You have not added any medicines to this prescription.\n\n' +
                        'Are you sure you want to save it without any medicines?'
                    );
                    if (!confirmed) {
                        e.preventDefault();
                        return false;
                    }
                }

                // Disable the submit button to prevent double submission
                $('#submitBtn')
                    .prop('disabled', true)
                    .html('<span class="spinner-border spinner-border-sm me-2"></span>Saving...');
            });

            // ── Diagnosis character counter (nice UX touch for doctors)
            const diagnosisField = $('#diagnosisField');
            const maxLength = 500;

            // Add a small counter below the diagnosis textarea
            diagnosisField.after(
                '<div class="d-flex justify-content-between mt-1">' +
                    '<span class="text-danger small" id="diagnosisValidation"></span>' +
                    '<span class="text-muted small" id="diagnosisCounter">0 / ' + maxLength + '</span>' +
                '</div>'
            );

            diagnosisField.on('input', function () {
                const length = $(this).val().length;
                $('#diagnosisCounter').text(length + ' / ' + maxLength);
                if (length > maxLength) {
                    $('#diagnosisCounter').addClass('text-danger').removeClass('text-muted');
                } else {
                    $('#diagnosisCounter').addClass('text-muted').removeClass('text-danger');
                }
            });

            // Trigger once on load in case the field is pre-filled (e.g. validation failure return)
            diagnosisField.trigger('input');

        });
    </script>
}