@model SmartHealthcare.Models.DTOs.LoginDTO
@{
    ViewData["Title"] = "Login";
}

<div class="scene">

    
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>

    
    <div class="grid-overlay"></div>

    <div class="layout">

        
        <div class="brand-panel">
            <div class="brand-inner">
                <div class="brand-badge">
                    <span class="badge-dot"></span>
                    System Online
                </div>

                <div class="brand-logo">
                    <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="60" height="60" rx="18" fill="url(#logoGrad)"/>
                        <path d="M30 12v36M12 30h36" stroke="white" stroke-width="5" stroke-linecap="round"/>
                        <circle cx="30" cy="30" r="10" fill="none" stroke="rgba(255,255,255,0.35)" stroke-width="2"/>
                        <defs>
                            <linearGradient id="logoGrad" x1="0" y1="0" x2="60" y2="60" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#00E5FF"/>
                                <stop offset="1" stop-color="#7B2FF7"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>

                <h1 class="brand-name">Smart<br>Healthcare</h1>
                <p class="brand-tagline">Precision care,<br>delivered intelligently.</p>

                <div class="brand-stats">
                    <div class="stat">
                        <span class="stat-value">98%</span>
                        <span class="stat-label">Uptime</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <span class="stat-value">2.4k</span>
                        <span class="stat-label">Patients</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <span class="stat-value">140+</span>
                        <span class="stat-label">Doctors</span>
                    </div>
                </div>

                <div class="brand-quote">
                    <span class="quote-mark">"</span>
                    Connecting patients with the right care at the right time.
                </div>
            </div>
        </div>

        
        <div class="form-panel">
            <div class="form-card">

                <div class="form-top">
                    <p class="form-eyebrow">Welcome back</p>
                    <h2 class="form-title">Sign in to<br>your account</h2>
                </div>

                <form asp-action="Login" method="post" novalidate class="login-form">
                    <div asp-validation-summary="All" class="error-box" role="alert"></div>

                    <div class="field-group">
                        <label asp-for="Email" class="field-label">Email Address</label>
                        <div class="field-wrap">
                            <svg class="field-icon" viewBox="0 0 20 20" fill="none">
                                <path d="M2.5 5.5L10 11l7.5-5.5M2.5 5.5h15v9h-15v-9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                            </svg>
                            <input asp-for="Email" class="field-input" placeholder="you@example.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Password" class="field-label">Password</label>
                        <div class="field-wrap">
                            <svg class="field-icon" viewBox="0 0 20 20" fill="none">
                                <rect x="4" y="9" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            <input asp-for="Password" class="field-input" type="password" placeholder="••••••••" autocomplete="current-password" id="pwdInput"/>
                            <button type="button" class="toggle-pwd" onclick="togglePwd()" title="Toggle password visibility" tabindex="-1">
                                <svg id="eyeIcon" viewBox="0 0 20 20" fill="none">
                                    <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke="currentColor" stroke-width="1.5"/>
                                    <circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-error"></span>
                    </div>

                    <div class="form-row">
                        <label class="checkbox-label">
                            <input type="checkbox" class="checkbox-input" id="rememberMe" />
                            <span class="checkbox-custom"></span>
                            Remember me
                        </label>
                        <a href="#" class="forgot-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="submit-btn">
                        <span class="btn-text">Sign In</span>
                        <svg class="btn-arrow" viewBox="0 0 20 20" fill="none">
                            <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <div class="btn-shine"></div>
                    </button>

                    <div class="demo-box">
                        <span class="demo-label">Demo Access</span>
                        <div class="demo-creds">
                            <span>admin@healthcare.com</span>
                            <span class="demo-sep">·</span>
                            <span>Admin@123</span>
                        </div>
                    </div>
                </form>

                <div class="form-footer">
                    No account?
                    <a asp-action="Register" class="register-link">
                        Create one
                        <svg viewBox="0 0 16 16" fill="none">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </div>

            </div>

            <p class="support-text">
                Issues? <a href="mailto:support@healthcare.com">support@healthcare.com</a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
@@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --cyan:    #00E5FF;
    --violet:  #7B2FF7;
    --pink:    #FF3CAC;
    --green:   #00FFA3;
    --dark:    #080B14;
    --dark2:   #0E1220;
    --dark3:   #141929;
    --glass:   rgba(255,255,255,0.045);
    --glass2:  rgba(255,255,255,0.07);
    --border:  rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.13);
    --text:    #E8EEFF;
    --muted:   rgba(200,210,255,0.55);
    --font-display: 'Syne', sans-serif;
    --font-body:    'DM Sans', sans-serif;
}

html, body {
    height: 100%;
    background: var(--dark);
    color: var(--text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
}


.scene {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 50%, #0a0e1f 0%, var(--dark) 70%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}


.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    pointer-events: none;
}
.orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--violet) 0%, transparent 70%);
    top: -150px; left: -100px;
    animation: driftA 18s ease-in-out infinite alternate;
}
.orb-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--cyan) 0%, transparent 70%);
    bottom: -100px; right: -80px;
    animation: driftB 22s ease-in-out infinite alternate;
    opacity: 0.35;
}
.orb-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, var(--pink) 0%, transparent 70%);
    top: 60%; left: 40%;
    animation: driftC 14s ease-in-out infinite alternate;
    opacity: 0.2;
}
.orb-4 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, var(--green) 0%, transparent 70%);
    top: 10%; right: 30%;
    animation: driftA 25s ease-in-out infinite alternate-reverse;
    opacity: 0.15;
}

@@keyframes driftA {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(60px, 80px) scale(1.15); }
}
@@keyframes driftB {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-50px, -60px) scale(1.1); }
}
@@keyframes driftC {
    from { transform: translate(0, 0) scale(0.9); }
    to   { transform: translate(40px, -50px) scale(1.2); }
}


.grid-overlay {
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}


.layout {
    position: relative; z-index: 10;
    display: flex;
    width: min(1060px, 95vw);
    min-height: min(620px, 92vh);
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow:
        0 0 0 1px rgba(255,255,255,0.04),
        0 40px 100px rgba(0,0,0,0.7),
        0 0 80px rgba(123,47,247,0.15);
    animation: panelIn 0.9s cubic-bezier(0.22,1,0.36,1) both;
}

@@keyframes panelIn {
    from { opacity: 0; transform: translateY(40px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}


.brand-panel {
    width: 42%;
    background: linear-gradient(145deg, rgba(123,47,247,0.55) 0%, rgba(0,229,255,0.2) 100%);
    border-right: 1px solid var(--border);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 3rem 2.5rem;
}

.brand-panel::before {
    content: '';
    position: absolute; inset: 0;
    background:
        radial-gradient(circle at 30% 20%, rgba(0,229,255,0.25) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(123,47,247,0.35) 0%, transparent 50%);
}


.brand-panel::after {
    content: '';
    position: absolute;
    width: 420px; height: 420px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.07);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: spinSlow 40s linear infinite;
}

@@keyframes spinSlow {
    to { transform: translate(-50%, -50%) rotate(360deg); }
}

.brand-inner {
    position: relative; z-index: 2;
    display: flex; flex-direction: column;
    gap: 1.5rem;
}

.brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,255,163,0.12);
    border: 1px solid rgba(0,255,163,0.3);
    color: var(--green);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    width: fit-content;
    animation: fadeUp 0.7s 0.3s both;
}

.badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: blink 2s ease-in-out infinite;
}

@@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}

.brand-logo svg {
    width: 56px; height: 56px;
    filter: drop-shadow(0 0 20px rgba(0,229,255,0.5));
    animation: fadeUp 0.7s 0.4s both;
}

.brand-name {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #fff;
    animation: fadeUp 0.7s 0.5s both;
}

.brand-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.6;
    animation: fadeUp 0.7s 0.6s both;
}

.brand-stats {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 0.5rem;
    animation: fadeUp 0.7s 0.7s both;
}

.stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
}

.stat-value {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--cyan);
    line-height: 1;
}

.stat-label {
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
}

.stat-divider {
    width: 1px; height: 36px;
    background: var(--border2);
}

.brand-quote {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
    border-left: 2px solid var(--violet);
    padding-left: 0.9rem;
    max-width: 230px;
    animation: fadeUp 0.7s 0.8s both;
}

.quote-mark {
    font-size: 1.5rem;
    color: var(--violet);
    font-family: Georgia, serif;
    line-height: 0;
    vertical-align: -0.25rem;
    margin-right: 0.15rem;
}


.form-panel {
    flex: 1;
    background: var(--dark2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 3.5rem;
    gap: 1.25rem;
    overflow-y: auto;
}

.form-card {
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    animation: fadeUp 0.7s 0.2s both;
}

.form-top { display: flex; flex-direction: column; gap: 0.4rem; }

.form-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
}

.form-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
}


.login-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
}

.field-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
}

.field-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.03em;
}

.field-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.field-icon {
    position: absolute;
    left: 1rem;
    width: 17px; height: 17px;
    color: rgba(200,210,255,0.35);
    pointer-events: none;
    transition: color 0.2s;
}

.field-wrap:focus-within .field-icon {
    color: var(--cyan);
}

.field-input {
    width: 100%;
    background: var(--glass2);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    outline: none;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    -webkit-appearance: none;
}

.field-input::placeholder { color: rgba(200,210,255,0.25); }

.field-input:focus {
    border-color: var(--cyan);
    background: rgba(0,229,255,0.05);
    box-shadow: 0 0 0 3px rgba(0,229,255,0.1), inset 0 0 20px rgba(0,229,255,0.04);
}

.toggle-pwd {
    position: absolute; right: 0.9rem;
    background: none; border: none; cursor: pointer;
    color: rgba(200,210,255,0.3);
    display: flex; align-items: center;
    padding: 0.2rem;
    transition: color 0.2s;
}
.toggle-pwd:hover { color: var(--cyan); }
.toggle-pwd svg { width: 17px; height: 17px; }

.field-error {
    font-size: 0.75rem;
    color: #FF6B8A;
    display: block;
}

.error-box {
    background: rgba(255,60,100,0.1);
    border: 1px solid rgba(255,60,100,0.3);
    border-radius: 10px;
    color: #FF8FA0;
    font-size: 0.82rem;
    padding: 0.65rem 0.9rem;
}
.error-box:empty { display: none; }


.form-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: -0.2rem;
}

.checkbox-label {
    display: flex; align-items: center;
    gap: 0.55rem;
    cursor: pointer;
    font-size: 0.82rem;
    color: var(--muted);
    user-select: none;
}

.checkbox-input { display: none; }

.checkbox-custom {
    width: 17px; height: 17px;
    border: 1.5px solid var(--border2);
    border-radius: 5px;
    background: var(--glass);
    display: grid; place-items: center;
    transition: all 0.2s;
    flex-shrink: 0;
}

.checkbox-input:checked + .checkbox-custom {
    background: var(--cyan);
    border-color: var(--cyan);
    box-shadow: 0 0 10px rgba(0,229,255,0.4);
}

.checkbox-input:checked + .checkbox-custom::after {
    content: '';
    width: 4px; height: 7px;
    border-right: 2px solid #000;
    border-bottom: 2px solid #000;
    transform: rotate(45deg) translate(-1px, -1px);
    display: block;
}

.forgot-link {
    font-size: 0.8rem;
    color: var(--cyan);
    text-decoration: none;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s;
}
.forgot-link:hover { opacity: 1; }


.submit-btn {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: linear-gradient(135deg, var(--violet) 0%, #9b4dff 50%, var(--cyan) 100%);
    background-size: 200% 200%;
    border: none;
    border-radius: 12px;
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 8px 30px rgba(123,47,247,0.4), 0 2px 8px rgba(0,0,0,0.3);
    margin-top: 0.4rem;
    animation: gradientShift 4s ease infinite;
}

@@keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(123,47,247,0.55), 0 4px 12px rgba(0,0,0,0.3);
}

.submit-btn:active { transform: translateY(0); }

.btn-text { position: relative; z-index: 1; }

.btn-arrow {
    width: 18px; height: 18px;
    position: relative; z-index: 1;
    transition: transform 0.3s;
}

.submit-btn:hover .btn-arrow { transform: translateX(4px); }

.btn-shine {
    position: absolute;
    top: -100%; left: -100%;
    width: 60%; height: 300%;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.18) 50%, transparent 60%);
    transform: rotate(25deg);
    transition: left 0.5s ease, top 0.5s ease;
}

.submit-btn:hover .btn-shine {
    left: 150%; top: -100%;
}


.demo-box {
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: -0.1rem;
}

.demo-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cyan);
    white-space: nowrap;
    flex-shrink: 0;
}

.demo-creds {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--muted);
    flex-wrap: wrap;
}

.demo-sep { color: var(--border2); }


.form-footer {
    text-align: center;
    font-size: 0.82rem;
    color: var(--muted);
    padding-top: 0.25rem;
}

.register-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--cyan);
    font-weight: 600;
    text-decoration: none;
    margin-left: 0.3rem;
    transition: gap 0.2s;
}
.register-link svg { width: 14px; height: 14px; }
.register-link:hover { gap: 0.5rem; }


.support-text {
    font-size: 0.73rem;
    color: rgba(200,210,255,0.3);
}
.support-text a {
    color: rgba(200,210,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
}
.support-text a:hover { color: var(--cyan); }


@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}


@@media (max-width: 768px) {
    html, body { overflow: auto; }

    .scene { position: relative; min-height: 100vh; }

    .layout {
        flex-direction: column;
        min-height: auto;
        border-radius: 20px;
        margin: 1.5rem;
        width: calc(100vw - 3rem);
    }

    .brand-panel {
        width: 100%;
        padding: 2rem 2rem 1.5rem;
        border-right: none;
        border-bottom: 1px solid var(--border);
    }

    .brand-inner { gap: 1rem; }

    .brand-panel::after { display: none; }

    .brand-name { font-size: 2rem; }

    .form-panel {
        padding: 2rem 1.75rem;
    }
}

@@media (max-width: 480px) {
    .layout { margin: 1rem; width: calc(100vw - 2rem); border-radius: 16px; }
    .brand-panel { padding: 1.5rem; }
    .form-panel { padding: 1.5rem; }
    .form-title { font-size: 1.65rem; }
    .brand-stats { gap: 0.8rem; }
    .demo-creds { flex-direction: column; gap: 0.15rem; }
    .demo-sep { display: none; }
}
</style>

<script>
    function togglePwd() {
        const input = document.getElementById('pwdInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
