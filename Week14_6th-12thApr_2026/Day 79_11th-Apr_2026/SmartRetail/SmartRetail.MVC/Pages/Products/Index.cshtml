@model List<SmartRetail.MVC.Models.Product>

@{
    ViewData["Title"] = "SmartRetail - Product Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Product Dashboard</h2>
        <a asp-action="Create" class="btn btn-success">+ Add New Product</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No products found. Add your first product!</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Product Name</th>
                    <th>Price (₹)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Id</td>
                        <td>@product.Name</td>
                        <td>@product.Price.ToString("F2")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@product.Id"
                               class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@product.Id"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>