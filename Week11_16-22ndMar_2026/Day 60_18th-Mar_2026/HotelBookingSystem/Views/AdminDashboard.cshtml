<h2>Dashboard</h2>

<canvas id="chart"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var ctx = document.getElementById('chart');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Rooms', 'Bookings'],
            datasets: [{
                label: 'Stats',
                data: [@ViewBag.TotalRooms, @ViewBag.TotalBookings]
            }]
        }
    });
</script>