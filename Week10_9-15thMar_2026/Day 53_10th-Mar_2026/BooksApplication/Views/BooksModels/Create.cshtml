@model BooksApplication.Models.BooksModel

@{
    ViewData["Title"] = "Create Book";
}

<style>

    body {
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg,#667eea,#764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-container {
        width: 40%;
        margin: 80px auto;
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    h1 {
        text-align: center;
        color: #333;
        margin-bottom: 10px;
    }

    h4 {
        text-align: center;
        color: #777;
        margin-bottom: 20px;
    }

    hr {
        margin-bottom: 25px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 5px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 14px;
        transition: 0.2s;
    }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102,126,234,0.5);
        }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        border: none;
        font-weight: 500;
        cursor: pointer;
        transition: 0.3s;
    }

    .create-btn {
        background: linear-gradient(45deg,#36d1dc,#5b86e5);
        color: white;
    }

    .back-btn {
        background: #6c757d;
        color: white;
        text-decoration: none;
        display: inline-block;
        margin-top: 10px;
        padding: 10px 18px;
    }

        .btn:hover, .back-btn:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

    .text-danger {
        font-size: 13px;
    }

    .back-container {
        text-align: center;
        margin-top: 15px;
    }

</style>


<div class="page-container">

    <h1>📚 Create Book</h1>

    <h4>BooksModel</h4>
    <hr />

    <form asp-action="Create">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="BookName"></label>
            <input asp-for="BookName" class="form-control" />
            <span asp-validation-for="BookName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="AuthorName"></label>
            <input asp-for="AuthorName" class="form-control" />
            <span asp-validation-for="AuthorName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <input type="submit" value="Create" class="btn create-btn" />
        </div>

    </form>

    <div class="back-container">
        <a asp-action="Index" class="back-btn">← Back to List</a>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}