@model BooksApplication.Models.BooksModel

@{
    ViewData["Title"] = "Delete Book";
}

<style>

    body {
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg,#667eea,#764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-container {
        width: 40%;
        margin: 80px auto;
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        text-align: center;
    }

    h1 {
        color: #333;
        margin-bottom: 10px;
    }

    h3 {
        color: #c0392b;
        margin-bottom: 25px;
    }

    h4 {
        color: #777;
        margin-bottom: 15px;
    }

    hr {
        margin-bottom: 25px;
    }

    dl {
        text-align: left;
        margin-bottom: 25px;
    }

    dt {
        font-weight: 600;
        color: #444;
        margin-top: 10px;
    }

    dd {
        margin-left: 0;
        margin-bottom: 10px;
        padding: 8px;
        background: #f5f7ff;
        border-radius: 6px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 500;
        margin: 5px;
        display: inline-block;
        transition: 0.3s;
        border: none;
        cursor: pointer;
    }

    .delete-btn {
        background: linear-gradient(45deg,#ff416c,#ff4b2b);
        color: white;
    }

    .back-btn {
        background: #6c757d;
        color: white;
    }

    .btn:hover {
        transform: scale(1.05);
        opacity: 0.9;
    }

</style>


<div class="page-container">

    <h1>🗑 Delete Book</h1>

    <h3>Are you sure you want to delete this?</h3>

    <h4>BooksModel</h4>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BookName)
        </dt>

        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BookName)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AuthorName)
        </dt>

        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AuthorName)
        </dd>

    </dl>

    <form asp-action="Delete">

        <input type="hidden" asp-for="BookModelId" />

        <input type="submit" value="Delete" class="btn delete-btn" />

        <a asp-action="Index" class="btn back-btn">Back to List</a>

    </form>

</div>